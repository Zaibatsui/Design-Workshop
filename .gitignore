# See https://help.github.com/articles/ignoring-files/ for more on ignoring files.

# --- Environment & credentials ---
.env
.env.*
*.env
*.pem
*.key
.credentials
credentials.json
*token.json*
*credentials.json*

# Whitelist .env.example placeholders (no real secrets).
# MUST come after the .env.* rules above so they actually take effect.
!.env.example
!deploy/.env.example
!backend/.env.example
!frontend/.env.example

# --- Internal / Emergent platform artefacts (not for public mirror) ---
.emergent/
.gitconfig
memory/
test_reports/
test_result.md
auth_testing.md
design_guidelines.json

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Build output ---
/build
dist/
/coverage
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# --- Caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/

# --- Python ---
__pycache__/
*.pyc
venv/
.venv/

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# --- OS / Editors ---
.DS_Store
.idea/
.vscode/

# --- Archives & large assets ---
**/*.zip
**/*.tar
**/*.tar.gz
**/*.tgz
*.pack
*.deb
*.dylib

# --- Deployment platform leftovers ---
.vercel

# --- Generated promo video assets (regenerate with /video/build.sh) ---
/video/frames/
/video/output/

# --- Build / dev caches (covered by node_modules above, but the
# webpack cache occasionally ends up tracked when node_modules is
# stashed; this catches stragglers explicitly) ---
**/node_modules/.cache/
frontend/node_modules/.cache/default-development/29.pack
frontend/node_modules/.cache/default-development/1.pack
frontend/node_modules/.cache/default-development/14.pack
frontend/node_modules/.cache/default-development/18.pack
frontend/node_modules/.cache/default-development/2.pack
frontend/node_modules/.cache/default-development/4.pack
frontend/node_modules/.cache/default-development/5.pack
