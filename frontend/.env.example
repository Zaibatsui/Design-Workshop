# Design Workshop — Frontend environment template.
# Copy this file to `.env` and fill in real values for your deployment.
# Never commit a real `.env` file.

# Public URL where the backend FastAPI server is reachable. The frontend
# calls every `/api/...` endpoint against this base URL.
# For local dev with the bundled docker-compose / supervisor stack:
REACT_APP_BACKEND_URL="http://localhost:8001"
