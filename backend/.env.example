# Design Workshop — Backend environment template.
# Copy this file to `.env` and fill in real values for your deployment.
# Never commit a real `.env` file.

# --- Application ---
APP_NAME="Design Workshop"

# --- MongoDB ---
# Connection string for your MongoDB instance. For local development the
# default below works with a Mongo running on localhost:27017.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="design_workshop"

# --- CORS ---
# Comma-separated list of origins allowed to call this API. Use "*" for
# local dev; lock to your real frontend origin(s) in production.
CORS_ORIGINS="*"

# --- OAuth state ---
# Secret used to sign one-shot OAuth state cookies. Generate a long
# random string for production (e.g. `openssl rand -hex 48`).
OAUTH_STATE_SECRET="change-me-in-production"

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# and add `${FRONTEND_URL}/auth/google/callback` as an authorised redirect URI.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Optional integrations ---
# Used by AI-assisted features. Optional; leave blank to disable.
EMERGENT_LLM_KEY=""

# --- Admin allowlist ---
# Comma-separated list of emails that get admin privileges (Tickets
# inbox, Users page, etc.). Match the casing of the address Google
# returns; matching is case-insensitive. Leave blank for a fresh
# install — admin endpoints will simply be inaccessible until you set
# at least one.
ADMIN_EMAILS=""
