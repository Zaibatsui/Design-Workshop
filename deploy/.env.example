# Public origin the browser will reach. Must match the OAuth redirect
# URI you register in Google Cloud Console:
#     https://your-domain.example.com/api/auth/google/callback
PUBLIC_URL=https://your-domain.example.com

# Host port the frontend container binds to. Point your reverse proxy
# (nginx / caddy / traefik / nginx-proxy-manager) at this port.
PUBLIC_PORT=8080

# MongoDB database name. Anything is fine; pick something memorable.
DB_NAME=design_workshop

# Used as the upload-path namespace (`<APP_NAME>/uploads/<uuid>.<ext>`).
# Keep this stable across redeploys — changing it breaks existing
# upload URLs stored in MongoDB.
APP_NAME=modular-pages

# Google OAuth credentials. Add the production redirect URI
#     https://your-domain.example.com/api/auth/google/callback
# under "Authorized redirect URIs" on the existing client in
# Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=replace-with-your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret

# Random 32+ byte string for signing the short-lived OAuth state cookie.
# Generate with: `openssl rand -hex 32`
OAUTH_STATE_SECRET=replace-with-openssl-rand-hex-32

# Comma-separated list of Google account emails that should get admin
# privileges (Tickets inbox, Users page, etc.). Leave blank to keep
# every user as a regular reporter until you're ready to promote
# someone. Case-insensitive.
ADMIN_EMAILS=
